# BID-ZONE Configuration File Template

# API Keys for AI Vision Services
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-cloud-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Database Configuration (if using database storage)
DATABASE_URL=sqlite:///bid_zone.db

# File Storage Configuration
UPLOAD_FOLDER=./uploads
OUTPUT_FOLDER=./output
TEMP_FOLDER=./temp

# Application Settings
DEBUG=False
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,tiff,dwg,dxf

# Report Generation Settings
DEFAULT_SCALE=1:100
DEFAULT_PAGE_SIZE=letter
INCLUDE_WATERMARK=False
COMPANY_NAME=Your Company Name
COMPANY_LOGO=./assets/logo.png

# Estimation Settings
DEFAULT_CONTINGENCY_PERCENT=15.0
DEFAULT_MARKUP_PERCENT=10.0
USE_HISTORICAL_PRICING=True

# Land Planning Settings
DEFAULT_ZONING=R-1
DEFAULT_LOT_SIZE_SF=8000
DEFAULT_SETBACK_FRONT=25
DEFAULT_SETBACK_REAR=20
DEFAULT_SETBACK_SIDE=5

# Earthwork Settings
DEFAULT_SWELL_FACTOR=0.25
DEFAULT_SHRINKAGE_FACTOR=0.10
DEFAULT_COMPACTION_REQUIREMENT=0.95

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
NOTIFICATION_ENABLED=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/bid_zone.log
