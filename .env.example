# =============================================================================
# BID-ZONE Configuration - Comprehensive Platform
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys for AI Services
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_cloud_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///bid_zone.db
# For PostgreSQL: postgresql://user:password@localhost/bid_zone
# For MySQL: mysql://user:password@localhost/bid_zone

# -----------------------------------------------------------------------------
# File Storage Configuration
# -----------------------------------------------------------------------------
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
TEMP_FOLDER=temp
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,tiff,dwg,dxf,zip

# -----------------------------------------------------------------------------
# Flask Application Settings
# -----------------------------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_here_change_in_production

# -----------------------------------------------------------------------------
# AI Agent Settings
# -----------------------------------------------------------------------------
AI_MODEL=gpt-4
AI_TEMPERATURE=0.1
MAX_TOKENS=4000
ENABLE_AGENT_COORDINATION=True
MAX_PARALLEL_AGENTS=4

# -----------------------------------------------------------------------------
# Report Generation Settings
# -----------------------------------------------------------------------------
DEFAULT_SCALE=1:100
DEFAULT_PAGE_SIZE=letter
INCLUDE_WATERMARK=False
COMPANY_NAME=Your Company Name
COMPANY_LOGO=./assets/logo.png

# -----------------------------------------------------------------------------
# Construction Estimation Settings
# -----------------------------------------------------------------------------
DEFAULT_CONTINGENCY_PERCENT=15.0
DEFAULT_MARKUP_PERCENT=10.0
USE_HISTORICAL_PRICING=True
CSI_DIVISION_FORMAT=2016

# -----------------------------------------------------------------------------
# Land Planning Settings
# -----------------------------------------------------------------------------
DEFAULT_ZONING=R-1
DEFAULT_LOT_SIZE_SF=8000
DEFAULT_SETBACK_FRONT=25
DEFAULT_SETBACK_REAR=20
DEFAULT_SETBACK_SIDE=5
GENERATE_LAYOUT_OPTIONS=5

# -----------------------------------------------------------------------------
# Earthwork Settings
# -----------------------------------------------------------------------------
DEFAULT_SWELL_FACTOR=0.25
DEFAULT_SHRINKAGE_FACTOR=0.10
DEFAULT_COMPACTION_REQUIREMENT=0.95
ENABLE_ROCK_DETECTION=True

# -----------------------------------------------------------------------------
# Email Notifications (Optional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
NOTIFICATION_ENABLED=False

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/bid_zone.log
ENABLE_AUDIT_LOG=True

# -----------------------------------------------------------------------------
# Performance & Caching
# -----------------------------------------------------------------------------
ENABLE_CACHING=True
CACHE_TYPE=redis
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Docker & Deployment
# -----------------------------------------------------------------------------
WORKERS=4
TIMEOUT=300
BIND=0.0.0.0:5000
